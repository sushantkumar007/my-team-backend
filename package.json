  "type": "module",
  "main": "./src/index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon --legacy-watch src/index.js",
    "start": "cross-env NODE_ENV=production node src/index.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "prepare": "husky install",
    "seed:admin": "node src/seed/admin.seed.js"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --max-warnings=0"
    ],
    "*.{yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "mailgen": "^2.0.32",
    "mongoose": "^9.3.3",
    "multer": "^2.1.1",
    "resend": "^6.9.4"
  }
